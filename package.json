{
  "name": "swi-v1-01-ethical-core-stack",
  "version": "4.7.0",
  "description": "Research prototype for governance-aware AI execution",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "health-check": "tsx scripts/health_check.ts",
    "simulate": "tsx scripts/node_simulator.ts",
    "audit": "tsx scripts/audit_replay.ts",
    "build": "npm run build:core && npm run build:hashseal",
    "build:core": "tsc && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:hashseal": "node scripts/hashseal.mjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist build .cache .turbo",
    "install:ci": "pnpm install --frozen-lockfile",
    "verify": "tsx scripts/swi-verify.ts",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "swi:ci": "tsx scripts/swi-ci-check.ts",
    "swi:lint": "eslint . --rule 'swi/no-index-keys: error'"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@noir-lang/backend_barretenberg": "^0.36.0",
