    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "js-sha256": "^0.11.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.284.0",
    "motion": "^12.4.7",
    "node-forge": "^1.4.0",
    "pdfkit": "^0.18.0",
    "protobufjs": "^7.4.0",
    "qrcode.react": "^4.2.0",
    "qs": "^6.15.3",
