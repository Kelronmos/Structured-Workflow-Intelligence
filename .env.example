############################################
# Structured Workflow Intelligence (SWI)
# Environment Configuration - ISO Aligned
############################################

############################
# AI PLATFORM INTEGRATION LAYER
############################

# Primary LLM Provider API Key
# Injected via platform secret manager (Google AI Studio, Cloud Run, or equivalent)
AI_API_KEY="REDACTED_AT_RUNTIME"

# LLM Provider Selection
# Supported: gemini | openai | anthropic | local | custom
AI_PROVIDER="gemini"

# Model Selection (provider-dependent)
AI_MODEL="gemini-1.5-pro"

############################
# PLATFORM ABSTRACTION LAYER
############################

# Base Application URL (deployment-agnostic)
# Injected at runtime by hosting environment
BASE_URL="REDACTED_AT_RUNTIME"

# Hosting Environment Type
# Supported: ai_studio | cloud_run | kubernetes | local | edge
DEPLOYMENT_PLATFORM="ai_studio"

# Runtime Injection Mode
# Defines how secrets/config are injected
SECRET_INJECTION_MODE="managed_vault"

############################
# GOOGLE AI STUDIO COMPATIBILITY (OPTIONAL LAYER)
############################

# Enable Google AI Studio integration mode
GOOGLE_AI_STUDIO_MODE="true"

# Google-managed secret injection flag
GOOGLE_SECRET_MANAGER_ENABLED="true"

# Cloud Run compatibility toggle
CLOUD_RUN_COMPATIBILITY="true"

############################
# SECURITY & CRYPTO LAYER
############################

# Hardware Security Module Root Secret
# MUST be stored in real HSM or secure vault (NOT plaintext in production)
HSM_SECRET="MOVE_TO_SECURE_VAULT"

# SWI Continuation Control Secret
# Used for session continuity + execution chaining integrity
SWI_CONTINUATION_SECRET="MOVE_TO_SECURE_VAULT"

# SWI RSA Private Key
# Used for JWT signing and cryptographic gating
SWI_PRIVATE_KEY="MOVE_TO_SECURE_VAULT"

# Zero-Knowledge System Salt
# Used for deterministic privacy-preserving proofs
SWI_ZK_SECRET="MOVE_TO_SECURE_VAULT"

############################
# STRUCTURED WORKFLOW INTELLIGENCE GOVERNANCE MODE
############################

# Execution environment classification
# Allowed: DEVELOPMENT | REVIEW | STAGING | PRODUCTION
ENVIRONMENT="REVIEW"

# Hard safety flag for non-production isolation
NON_PRODUCTION="true"

# Forces session-based key rotation after review cycles
ROTATE_AFTER_REVIEW="true"

# Enables simulated HSM layer for sandbox testing only
MOCK_HSM_ENABLED="true"

############################
# SWI GOVERNANCE SAFETY RULES
############################

# Rule: No real secrets in non-production environments
SWI_RULE_SECRET_ISOLATION="ENFORCED"

# Rule: All secrets must pass vault abstraction layer in production
SWI_RULE_VAULT_REQUIRED="ENFORCED"

# Rule: Mock systems must NEVER be active in production
SWI_RULE_MOCK_FORBIDDEN_IN_PROD="ENFORCED"

############################
# DEPLOYMENT GUARDS
############################

# Prevent accidental production execution
DEPLOYMENT_GUARD="REVIEW_LOCK"

############################
# AUDIT & TRACEABILITY
############################

# Enable structured audit logging
SWI_AUDIT_LOGGING="ENABLED"

# Enable immutable event tracing
SWI_EVENT_TRACE="ENABLED"

# Compliance export readiness flag (ISO 42001 alignment)
SWI_COMPLIANCE_MODE="READY"
